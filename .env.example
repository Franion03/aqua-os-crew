OPENROUTER_API_KEY=sk-or-v1-...
GEMINI_API_KEY=AIza...

# ── AquaOS Calendar Service ───────────────────────────────────────
# URL of the aqua-os-calendar microservice (C# .NET)
CALENDAR_SERVICE_URL=http://localhost:8082
# JWT token for authenticated writes (obtain via POST /api/auth/login)
# Leave empty if calendar is used read-only (get_upcoming_events only)
CALENDAR_API_KEY=
# Default calendar series ID for crew operations
CALENDAR_DEFAULT_SERIES=